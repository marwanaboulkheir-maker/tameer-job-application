{
  "name": "job-application-form-qr",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "minify": "terser script.js --compress passes=2 --mangle --output deploy/script.js && terser admin.js --compress passes=2 --mangle --output deploy/admin.js",
    "sync": "node -e \"const fs=require('fs');['index.html','admin.html','styles.css','admin.css','config.js'].forEach(f=>fs.copyFileSync(f,'deploy/'+f))\"",
    "prepare:deploy": "npm run minify && npm run sync",
    "deploy:cf": "npm run prepare:deploy && npx wrangler pages deploy deploy/ --project-name tameer-job-application",
    "deploy:firebase": "npm run prepare:deploy && npx firebase deploy --only hosting",
    "deploy:gateway": "cd gateway && npx wrangler deploy",
    "deploy:all": "npm run prepare:deploy && npm run deploy:cf && npm run deploy:firebase && npm run deploy:gateway"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
